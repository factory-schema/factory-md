{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://factoryschema.org/v0.3/factory.schema.json",
  "title": "Factory.md frontmatter",
  "description": "Validates the YAML frontmatter of a factory.md file — a machine-readable manufacturing facility profile.",
  "type": "object",
  "required": ["schema", "name", "location", "vertical"],

  "properties": {
    "schema": {
      "type": "string",
      "const": "https://factoryschema.org/v0.3/factory.schema.json",
      "description": "Must reference this schema."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Trade name of the factory."
    },
    "location": {
      "description": "Factory location as a string (\"City, Region, CC\") or a structured object.",
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "required": ["city", "country"],
          "properties": {
            "city": { "type": "string", "minLength": 1 },
            "region": { "type": "string" },
            "country": {
              "type": "string",
              "pattern": "^[A-Z]{2}$",
              "description": "ISO 3166-1 alpha-2 country code."
            },
            "postal_code": { "type": "string" },
            "timezone": {
              "type": "string",
              "description": "IANA timezone (e.g. \"Asia/Shanghai\")."
            },
            "coordinates": {
              "type": "object",
              "required": ["lat", "lng"],
              "properties": {
                "lat": { "type": "number", "minimum": -90, "maximum": 90 },
                "lng": { "type": "number", "minimum": -180, "maximum": 180 }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "vertical": {
      "type": "string",
      "minLength": 1,
      "description": "Primary industry vertical (free-form, e.g. \"machining\", \"pcb\", \"textiles\", \"sheet-metal\")."
    },
    "capabilities": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Manufacturing processes offered (free-form strings)."
    },
    "certifications": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Industry certifications and compliance credentials (e.g. \"ISO 9001:2015\")."
    },
    "website": {
      "type": "string",
      "format": "uri",
      "description": "Factory website URL."
    },
    "email": {
      "type": "string",
      "description": "Contact email address."
    },
    "updated_at": {
      "type": "string",
      "format": "date",
      "description": "Date the profile was last updated (YYYY-MM-DD)."
    },
    "has_inventory": {
      "type": "boolean",
      "description": "True if the factory exposes inventory data (e.g. stock, on-hand materials)."
    },
    "has_rfq": {
      "type": "boolean",
      "description": "True if the factory accepts RFQ (Request for Quote) submissions."
    },
    "has_agent_capabilities": {
      "type": "boolean",
      "description": "True if the factory publishes an A2A Agent Card or equivalent agent-callable endpoint."
    }
  },

  "additionalProperties": false
}
